GH_OWNER=seu-usuario-ou-sua-organizacao
GH_REPO=nome-do-repositorio
GITHUB_TOKEN=cole_aqui_o_token_do_github

# Necessário para publicar macOS em CI ou em máquinas sem o certificado já instalado no keychain.
CSC_LINK=cole_aqui_o_conteudo_base64_do_certificado_p12
CSC_KEY_PASSWORD=senha_do_certificado

# Necessário para notarização do macOS.
APPLE_ID=seu-email-da-apple
APPLE_APP_SPECIFIC_PASSWORD=senha-de-app-da-apple
APPLE_TEAM_ID=SEU_TEAM_ID
